{
  "$id": "system-robot.json",
  "type": "object",
  "required": ["name", "duration", "level", "permissions"],
  "properties": {
    "name": { "type": "string" },
    "description": { "type": "string" },
    "duration": { "type": "integer", "minimum": 1 },
    "level": {
      "type": "string",
      "enum": ["system"]
    },
    "permissions": {
      "type": "array",
      "items": {
        "$ref": "permissions.json"
      }
    }
  }
}